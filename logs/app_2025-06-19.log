CREATE TABLE teams (
	id INTEGER NOT NULL, 
	name VARCHAR(100) NOT NULL, 
	league VARCHAR(50) NOT NULL, 
	country VARCHAR(50), 
	founded INTEGER, 
	venue VARCHAR(100), 
	created_at DATETIME, 
	updated_at DATETIME, 
	PRIMARY KEY (id), 
	UNIQUE (name)
)


